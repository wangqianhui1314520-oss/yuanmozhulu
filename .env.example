# 元末逐鹿 4.0 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===== CodeBuddy API（通过腾讯云CodeBuddy代理调用DeepSeek-V3） =====
TENCENT_API_KEY=your_api_key_here

# ===== 模型配置（可选，默认使用内置配置） =====
# CodeBuddy v2端点仅支持流式，已内置处理
# ADVISOR_API_BASE=https://copilot.tencent.com/v2
# ADVISOR_MODEL_NAME=deepseek-v3
# ADVISOR_TEMPERATURE=0.7
# ADVISOR_MAX_TOKENS=4096

# LAW_API_BASE=https://copilot.tencent.com/v2
# LAW_MODEL_NAME=deepseek-v3
# LAW_TEMPERATURE=0.6
# LAW_MAX_TOKENS=8192

# ENEMY_API_BASE=https://copilot.tencent.com/v2
# ENEMY_MODEL_NAME=deepseek-v3
# ENEMY_TEMPERATURE=0.65
# ENEMY_MAX_TOKENS=2048

# ===== 服务配置 =====
# HOST=0.0.0.0
# PORT=8800
# DEBUG=false

# ===== 其他 =====
# MAX_CONCURRENT_REQUESTS=20
# FALLBACK_ENABLED=true
